# Enable MPU
CONFIG_ARM_MPU=y

# Hardware stack protection
CONFIG_HW_STACK_PROTECTION=y

# GPIO
CONFIG_GPIO=y

# USB stack (needed for DFU and CDC-ACM)
CONFIG_USB_DEVICE_STACK=y

# Low-frequency clock: this board has NO 32.768 kHz crystal, so the internal
# RC oscillator must be used. The Zephyr default for nRF52 is XTAL, and with
# that selected bt_enable() waits forever for an oscillator that never starts
# — the board hangs at boot before USB even enumerates. Bluetooth cannot work
# on this board without this.
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_500PPM=y
